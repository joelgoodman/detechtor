      "headContent": "\n<title>Oracle PeopleSoft Sign-in</title>\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=Edge\">\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=utf-8\">    \n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1.0,minimum-scale=1.0,user-scalable=yes\">  \n<meta name=\"apple-mobile-web-app-capable\" content=\"yes\">\n<meta name=\"mobile-web-app-capable\" content=\"yes\">\n<script language=\"JavaScript\">\n    var sDomain = \".nevada.edu\";\n    try {\n        document.domain = \".nevada.edu\";\n    }\n    catch (err) {; }\n</script>\n\n<script type=\"text/javascript\">\nif (self === top) {\n    var fb = document.getElementById(\"ptfb\");\n    fb.parentNode.removeChild(fb);\n} else {\n    try { \n        top.location = self.location;\n    } catch(ex) {}\n}\n</script>\n<link type=\"text/css\" href=\"/spcssprd/pt_custom_props.css\" rel=\"stylesheet\">\n\n<!-- \n\tRemoved delivered stylesheet link\n\tavasudeva 20210325\n-->\n<!--\n\t<link  type=\"text/css\" href=\"/spcssprd/signin.css\" rel=\"stylesheet\">\n-->\n<!-- \n\tEnd Change\n-->\n\n<!--\n\tMod to swap stylesheets and add custom password links\n\tavasudeva 20210325\n-->\n\t<link id=\"pagestyle\" type=\"text/css\" href=\"/spcssprd/wnc_signin.css\" rel=\"stylesheet\">\n\t\n\t<script language=\"JavaScript\">\n\t\n\t\tvar page_url = location.href;\n\t\tvar line1 = \" \";\n\t\tvar line2 = \" \";\n\t\tvar image1 = \" \";\n\t\t<!-- PNG 8173 - avasudeva - 11/25/2024 - add info for myTMCC login on Signin page - Start\n\t\t-->\n\t\tvar line3 = \" \";\n\t\tvar line4 = \" \";\n\t\t<!-- PNG 8173 - avasudeva - 11/25/2024 - add info for myTMCC login on Signin page - End\n\t\t-->\n\t\tfunction swapStyleSheet(sheet)\n\t\t{\n\t\t\tdocument.getElementById(\"pagestyle\").setAttribute(\"href\", sheet);\n\t\t}\n\t\t\n\t\tfunction checkSite(site)\n\t\t{\n\t\t\treturn page_url.search(site);\n\t\t}\t\n\t\t\t\n\t\tif (checkSite(\"/CSN/\") > -1)\n\t\t\t{ \n\t\t\t\tswapStyleSheet(\"/spcssprd/csn_signin.css\"); \n\t\t\t\tline1 = \"<a href='https://at.csn.edu/csn-password-admin'>Forgot your password?</a><br>\";\n\t\t\t\timage1 = \"<h1><img src='/spcssprd/images/csn_logo.png' class='ps-staticimg' alt='Oracle PeopleSoft Sign-in' title='MyCSN' ></h1>\";\n\t\t\t}\n\t\t\telse\n\t\t\t\t{\n\t\t\t\tif (checkSite(\"/GBC/\") > -1)\n\t\t\t\t\t{\n\t\t\t\t\t\tswapStyleSheet(\"/spcssprd/gbc_signin.css\");\n\t\t\t\t\t\tline1 = \"<a href='https://www.gbcnv.edu/passwords/'>Forgot your username?</a><br>\";\n\t\t\t\t\t\t<!-- PNG 3358 - avasudeva - 01/25/2023 - remove GBC Change Password Tile - Start \n\t\t\t\t\t\t-->\n\t\t\t\t\t\t/*\n\t\t\t\t\t\tline2 = \"<a href='/psc/spcssprd/GBC/SA/c/MAINTAIN_SECURITY.EMAIL_PSWD.GBL?Page=EMAIL_PSWD&Action=U'>Forgot your password?</a><br>\";\n\t\t\t\t\t\t*/\n\t\t\t\t\t\t<!-- PNG 3358 - avasudeva - 01/25/2023 - remove GBC Change Password Tile - End\n\t\t\t\t\t\t-->\n\t\t\t\t\t\timage1 = \"<h1><img src='/spcssprd/images/gbc_logo.png' class='ps-staticimg' alt='Oracle PeopleSoft Sign-in' title='MyGBC' ></h1>\";\n\t\t\t\t\t}\n\t\t\t\telse\n\t\t\t\t\t{\n\t\t\t\t\tif (checkSite(\"/NSC/\") > -1)\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\tswapStyleSheet(\"/spcssprd/nsc_signin.css\");\n\t\t\t\t\t\t\tline1 = \"<a href='https://my.nsc.edu/web/mycampus/reset-password'>Forgot your password?</a><br>\";\n\t\t\t\t\t\t\tline2 = \"<a href='https://my.nsc.edu/web/mycampus/5'>Need Help?</a><br>\";\n\t\t\t\t\t\t\timage1 = \"<h1><img src='/spcssprd/images/nsc_logo.png' class='ps-staticimg' alt='Oracle PeopleSoft Sign-in' title='MyNSC' ></h1>\";\n\t\t\t\t\t\t}\n\t\t\t\t\telse\n\t\t\t\t\t\t{\n\t\t\t\t\t\tif (checkSite(\"/TMC/\") > -1)\n\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\tswapStyleSheet(\"/spcssprd/tmcc_signin.css\");\n\t\t\t\t\t\t\t\tline1 = \"<a href='https://www.tmcc.edu/information-technology/students/self-service'>Forgot username or password?</a><br>\";\n\t\t\t\t\t\t\t\timage1 = \"<h1><img src='/spcssprd/images/tmcc_logo.png' class='ps-staticimg' alt='Oracle PeopleSoft Sign-in' title='MyTMCC' ></h1>\";\n\t\t\t\t\t\t\t\t<!-- PNG 8173 - avasudeva - 11/25/2024 - add info for myTMCC login on Signin page - Start\n\t\t\t\t\t\t\t\t-->\n\t\t\t\t\t\t\t\tline3 = \"<p style='color:white'>To sign in to MyTMCC, please enter your TMCC Username and Password</p><br>\";\n\t\t\t\t\t\t\t\tline4 = \"<br><p style='color:white'><b>Note:</b> Students are responsible for dropping classes they do not intend to complete.</p><br>\";\n\t\t\t\t\t\t\t\t<!-- PNG 8173 - avasudeva - 11/25/2024 - add info for myTMCC login on Signin page - End\n\t\t\t\t\t\t\t\t-->\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\telse\n\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\tif (checkSite(\"/WNC/\") > -1)\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\tswapStyleSheet(\"/spcssprd/wnc_signin.css\");\n\t\t\t\t\t\t\t\t\tline1 = \"<a href='https://www.wnc.edu/help/'>Can't Login?</a><br>\";\n\t\t\t\t\t\t\t\t\timage1 = \"<h1><img src='/spcssprd/images/wnc_logo.png' class='ps-staticimg' alt='Oracle PeopleSoft Sign-in' title='MyWNC' ></h1>\";\n\t\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\telse\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\tswapStyleSheet(\"/spcssprd/signin.css\");\n\t\t\t\t\t\t\t\t\timage1 = \"<h1 aria-label='Oracle PeopleSoft Sign-in'><img src='/spcssprd/images/OracleLogo_Black.svg' class='ps-staticimg' alt='Oracle PeopleSoft Sign-in' title='SCS' ><span class='ps_logo-PS'> PeopleSoft</span></h1>\";\n\t\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t} \t\n\t\t\t\t\t}\t\n\t\t\t\t}\n\t</script>\n<!--\n\tEnd Mod\n-->\n\n<!-- PNG 11412(PRD \"Sign Out\" not going to institutional page) 20251112 avasudeva - fixing Cookie issue - Start Change -->\n<!-- ===== function deleteCookieAllScopes - to delete cookie across common scopes & paths ===== -->\n<script type=\"text/javascript\">\nfunction deleteCookieAllScopes(name) {\n  var exp   = \"expires=Thu, 01 Jan 1970 00:00:00 GMT\";\n  var domains = [location.hostname, \".shr.nevada.edu\", \".scsr.nevada.edu\", \".nevada.edu\"];\n  var paths   = [\"/\", \"/psp\", \"/psc\"];\n\n  // domain-scoped